# Copy to .env for LOCAL testing only. On Render, set these in the dashboard
# under Environment. Never commit the real .env.

# BotFather token (same bot as WebsiteSellingBot)
TELEGRAM_BOT_TOKEN=your-bot-token

# Your personal Telegram numeric id (the DM target).
# Find it: deploy, DM your bot once, then open
#   https://<your-app>.onrender.com/get-chat-id?secret=YOUR_WEBHOOK_SECRET
TELEGRAM_CHAT_ID=123456789

# Shared secret. Supabase must send this in the x-webhook-secret header.
# Use a long random string (e.g. from a password generator).
WEBHOOK_SECRET=change-me-to-a-long-random-string

# Optional: only if TELEGRAM_CHAT_ID is a group with topics, not a DM.
# TELEGRAM_TOPIC_ID=8
